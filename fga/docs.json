{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Auth0 FGA",
  "seo": {
    "metatags": {
      "og:url": "https://docs.fga.dev",
      "canonical": "https://docs.fga.dev"
    }
  },
  "colors": {
    "primary": "#EB5424",
    "light": "#FF7C52",
    "dark": "#C43E13"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "heading": {
      "family": "Inter",
      "source": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap",
      "format": "woff2"
    },
    "body": {
      "family": "Inter",
      "source": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap",
      "format": "woff2"
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://docs.fga.dev"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Introduction",
            "icon": "book-open",
            "pages": [
              "intro/about-auth0-fga",
              "intro/authorization-concepts",
              "intro/fga-concepts"
            ]
          },
          {
            "group": "Getting started",
            "icon": "rocket-launch",
            "pages": [
              "getting-started/new-getting-started",
              "getting-started/perform-check"
            ]
          },
          {
            "group": "Modeling",
            "icon": "diagram-project",
            "pages": [
              "modeling/getting-started",
              "modeling/direct-access",
              "modeling/user-groups"
            ]
          },
          {
            "group": "API integration",
            "icon": "code",
            "pages": [
              "interacting/managing-user-access"
            ]
          },
          {
            "group": "Migrations & notices",
            "icon": "triangle-exclamation",
            "pages": [
              "migration-instructions"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/api", "destination": "/api/service" },
    { "source": "/intro/authorization-and-auth0-fga", "destination": "/intro/about-auth0-fga" },
    { "source": "/intro/auth0-fga-concepts", "destination": "/intro/fga-concepts" },
    { "source": "/intro/manage-accounts-and-members", "destination": "/dashboard/account" },
    { "source": "/modeling/basics/testing", "destination": "/modeling/testing" }
  ],
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://dashboard.fga.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign up",
      "href": "https://fga.dev"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/auth0",
      "github": "https://github.com/openfga",
      "linkedin": "https://linkedin.com/company/auth0"
    }
  }
}
